{
  "name": "to-become-demon-king-2d-release-tools",
  "private": true,
  "description": "To Become Demon King 2Dのリリース自動化ツール",
  "repository": {
    "type": "git",
    "url": "https://github.com/apaapapapapa/to-become-demon-king-2d.git"
  },
  "scripts": {
